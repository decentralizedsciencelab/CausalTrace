# CausalBench Generator Environment Configuration
# Copy this file to .env and fill in your values

# ============================================
# API Keys for Service Clients
# ============================================

# GitHub - Personal Access Token
# Create at: https://github.com/settings/tokens
# Required scopes: repo, read:org
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# Slack - Bot Token
# Create at: https://api.slack.com/apps
# Required scopes: channels:read, channels:history, chat:write, users:read
SLACK_TOKEN=xoxb-xxxxxxxxxxxx-xxxxxxxxxxxx-xxxxxxxxxxxxxxxx

# Stripe - API Key
# Get from: https://dashboard.stripe.com/apikeys
# Use test mode key for safety: sk_test_...
STRIPE_API_KEY=sk_test_xxxxxxxxxxxxxxxxxxxx

# Dropbox - Access Token
# Create at: https://www.dropbox.com/developers/apps
# Required scopes: files.metadata.read, files.content.read, sharing.read
DROPBOX_ACCESS_TOKEN=sl.xxxxxxxxxxxxxxxxxxxx

# Notion - Integration Token
# Create at: https://www.notion.so/my-integrations
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxx

# Trello - API Key and Token
# Get from: https://trello.com/app-key
TRELLO_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TRELLO_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Gmail - OAuth Credentials
# Create at: https://console.cloud.google.com/apis/credentials
# Download credentials JSON and save as credentials/gmail_credentials.json
GMAIL_CREDENTIALS_FILE=credentials/gmail_credentials.json
GMAIL_TOKEN_FILE=credentials/gmail_token.json

# ============================================
# LLM API Keys (for agent simulation)
# ============================================

# OpenAI
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxx

# Anthropic
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx

# Google (Gemini)
GOOGLE_API_KEY=AIzaxxxxxxxxxxxxxxxxxxxxxxxxx

# Azure OpenAI (alternative to OpenAI)
AZURE_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
AZURE_API_ENDPOINT=https://your-resource.openai.azure.com/

# ============================================
# Generation Settings
# ============================================

# Whether to simulate write operations (recommended: true)
SIMULATE_WRITES=true

# Default number of trajectories per batch
DEFAULT_BATCH_SIZE=1000

# Attack rate (fraction of trajectories with attacks)
DEFAULT_ATTACK_RATE=0.5

# Rate limiting (requests per minute per service)
RATE_LIMIT_RPM=30

# Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# ============================================
# Output Settings
# ============================================

# Output directory for generated trajectories
OUTPUT_DIR=output

# Whether to validate after generation
VALIDATE_AFTER_GENERATION=true

# Compression for large datasets (none, gzip, zstd)
OUTPUT_COMPRESSION=none

# ============================================
# Advanced Settings
# ============================================

# Redis URL for caching (optional)
# REDIS_URL=redis://localhost:6379

# Prometheus metrics port (optional)
# PROMETHEUS_PORT=8000

# Maximum concurrent API requests
MAX_CONCURRENT_REQUESTS=5

# Retry settings for failed API calls
MAX_RETRIES=3
RETRY_DELAY_SECONDS=5
